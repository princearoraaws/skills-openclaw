{
  "name": "openclaw-memory-plugin",
  "version": "1.0.1",
  "description": "Persistent memory system for OpenClaw multi-agent workflows — keyword indexing, BM25 semantic search, DAG linking, and session hooks.",
  "type": "module",
  "main": "index.js",
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": "1.0"
    }
  },
  "files": [
    "openclaw.plugin.json",
    "index.js",
    "scripts/",
    "skills/",
    "docs/"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "ai-agent",
    "bm25",
    "multi-agent",
    "recall"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/0xcjl/openclaw-memory-plugin"
  },
  "engines": {
    "node": ">=22"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "scripts": {
    "build": "echo 'No build step required — pure JS/TS plugin'",
    "test": "echo 'No tests yet'"
  }
}