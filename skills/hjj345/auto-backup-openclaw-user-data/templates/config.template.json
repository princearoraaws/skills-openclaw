{
  "version": "1.0.1",
  "createdAt": "",
  "updatedAt": "",
  
  "backup": {
    "mode": "full",
    "targets": ["workspace", "workspace-1", "workspace-2", "workspace-3", "memory",……],
    "exclude": ["logs", "cache", "tmp", "node_modules"],
    "excludePatterns": ["*.log", "*.tmp", ".DS_Store", "Thumbs.db"]
  },
  
  "schedule": {
    "enabled": true,
    "cron": "0 3 * * *",
    "timezone": "Asia/Shanghai",
    "lastRun": null
  },
  
  "output": {
    "path": "",
    "naming": {
      "prefix": "auto-backup-openclaw-user-data",
      "includeVersion": true,
      "includeSequence": true
    }
  },
  
  "retention": {
    "enabled": true,
    "mode": "count",
    "days": 30,
    "count": 10
  },
  
  "notification": {
    "enabled": true,
    "channels": ["feishu"],
    "targets": {},
    "onSuccess": true,
    "onFailure": true
  },
  
  "logging": {
    "enabled": true,
    "level": "info",
    "maxSize": "10MB",
    "maxFiles": 5
  }
}